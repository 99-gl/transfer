# Build a task image by starting from this file, then COPY/clone one clean repo
# into its declared workdir and install that repo's test dependencies.
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash ca-certificates coreutils git patch python3 python3-pip sudo tar \
    util-linux xz-utils && \
    rm -rf /var/lib/apt/lists/*

